{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "removeComments": false
  },
  "include": [
    "src/cli/**/*.ts",
    "src/core/**/*.ts",
    "src/providers/**/*.ts",
    "src/_stubs/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "_tasks",
    "**/*.test.ts",
    "**/__tests__/**"
  ]
}

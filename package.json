{
  "name": "mathran",
  "version": "0.12.0",
  "description": "Standalone agent runtime for mathematical reasoning + Lean theorem proving",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "mathran": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "docs/screenshots",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build:backend": "tsc -p tsconfig.build.json && tsx scripts/copy-builtin-skills.ts",
    "build:web": "cd web && npm ci && npm run build",
    "build:embedded-assets": "tsx scripts/build-static-assets.ts",
    "build:all": "npm run build:web && npm run build:embedded-assets && npm run build:backend",
    "build": "npm run build:all",
    "prepublishOnly": "npm run build:all",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run src/",
    "test:watch": "vitest",
    "e2e": "npm run build:all && playwright test",
    "e2e:headed": "npm run build:all && playwright test --headed",
    "cli": "tsx src/cli/index.ts",
    "doctor": "tsx src/cli/index.ts doctor"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@hono/node-server": "^2.0.6",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/diff": "^7.0.2",
    "@types/katex": "^0.16.8",
    "commander": "^15.0.0",
    "diff": "^9.0.0",
    "drizzle-orm": "^0.45.2",
    "gpt-tokenizer": "^3.4.0",
    "hono": "^4.12.27",
    "js-tiktoken": "^1.0.21",
    "katex": "^0.16.47",
    "openai": "^6.45.0",
    "smol-toml": "^1.7.0",
    "yaml": "^1.10.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^20",
    "happy-dom": "^20.10.6",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "keywords": [
    "lean",
    "lean4",
    "theorem-proving",
    "agent",
    "llm",
    "math",
    "ai4math",
    "formal-verification"
  ],
  "author": "subfish-zhou",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/subfish-zhou/mathran"
  }
}

{
  "name": "mathran",
  "version": "0.1.0-alpha.0",
  "description": "Standalone agent runtime for mathematical reasoning + Lean theorem proving",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "mathran": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run src/",
    "test:watch": "vitest",
    "cli": "tsx src/cli/index.ts",
    "doctor": "tsx src/cli/index.ts doctor",
    "prove": "tsx src/cli/index.ts prove"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@types/katex": "^0.16.8",
    "commander": "^15.0.0",
    "drizzle-orm": "^0.45.2",
    "js-tiktoken": "^1.0.21",
    "katex": "^0.16.47",
    "openai": "^6.25.0",
    "smol-toml": "^1.6.1",
    "yaml": "^1.10.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  },
  "keywords": [
    "lean",
    "lean4",
    "theorem-proving",
    "agent",
    "llm",
    "math",
    "ai4math",
    "formal-verification"
  ],
  "author": "subfish-zhou",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/subfish-zhou/mathran"
  }
}
